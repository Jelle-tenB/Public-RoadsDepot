SEARCH_MODEL_MERK=SELECT * FROM {table} WHERE REPLACE(model, ' ', '') LIKE ? AND REPLACE(merk, ' ', '') LIKE ?
SEARCH_MODEL=SELECT * FROM {table} WHERE REPLACE(model, ' ', '') LIKE ?
SEARCH_MERK=SELECT * FROM {table} WHERE REPLACE(merk, ' ', '') LIKE ?
SEARCH_CATEGORIE=SELECT * FROM {table}

CHECK_UNIQUE=SELECT 1 FROM {table} WHERE model LIKE ? AND merk LIKE ?
CHECK_UNIQUE_KABELS=SELECT 1 FROM {table} WHERE model LIKE ? AND lengte LIKE ?
CHECK_UNIQUE_VOEDINGEN=SELECT 1 FROM {table} WHERE soort LIKE ? AND wattage LIKE ? AND merk LIKE ?

UPDATE_DESKTOPS=UPDATE desktops SET merk=?, model=?, totaal=?, A_kwaliteit=?, B_kwaliteit=?, C_kwaliteit=?, CPU=?, ram=?, opslag=?, dvd=?, locatie=?, opmerking=? WHERE id=?
UPDATE_BEELDSCHERMEN=UPDATE beeldschermen SET merk=?, model=?, totaal=?, inch=?, VGA=?, DVI=?, displayport_in=?, displayport_out=?, HDMI=?, USB_A=?, USB_B=?, USB_C=?, ethernet=?, docking=?, webcam=?, speaker=?, locatie=?, opmerking=? WHERE id=?
UPDATE_LAPTOPS=UPDATE laptops SET merk=?, model=?, totaal=?, A_kwaliteit=?, B_kwaliteit=?, C_kwaliteit=?, CPU=?, ram=?, opslag=?, dvd=?, locatie=?, opmerking=? WHERE id=?
UPDATE_TOETSENBORDEN=UPDATE toetsenborden SET merk=?, model=?, totaal=?, nieuw=?, draadloos=?, opmerking=? WHERE id=?
UPDATE_MUIZEN=UPDATE muizen SET merk=?, model=?, totaal=?, nieuw=?, draadloos=?, opmerking=? WHERE id=?
UPDATE_MOBIELS=UPDATE mobiels SET merk=?, model=?, totaal=?, A_kwaliteit=?, B_kwaliteit=?, C_kwaliteit=?, opslag=?, opmerking=? WHERE id=?
UPDATE_KABELS=UPDATE kabels SET model=?, totaal=?, lengte=?, opmerking=? WHERE id=?
UPDATE_VOEDINGEN=UPDATE voedingen SET merk=?, wattage=?, soort=?, totaal=?, nieuw=?, opmerking=? WHERE id=?

INSERT_DESKTOPS=INSERT INTO desktops (merk, model, totaal, A_kwaliteit, B_kwaliteit, C_kwaliteit, CPU, ram, opslag, dvd, locatie, opmerking) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
INSERT_BEELDSCHERMEN=INSERT INTO beeldschermen (merk, model, totaal, inch, VGA, DVI, displayport_in, displayport_out, HDMI, USB_A, USB_B, USB_C, ethernet, docking, webcam, speaker, locatie, opmerking) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
INSERT_LAPTOPS=INSERT INTO laptops (merk, model, totaal, A_kwaliteit, B_kwaliteit, C_kwaliteit, CPU, ram, opslag, dvd, locatie, opmerking) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
INSERT_TOETSENBORDEN=INSERT INTO toetsenborden (merk, model, totaal, nieuw, draadloos, opmerking) VALUES (?, ?, ?, ?, ?, ?)
INSERT_MUIZEN=INSERT INTO muizen (merk, model, totaal, nieuw, draadloos, opmerking) VALUES (?, ?, ?, ?, ?, ?)
INSERT_MOBIELS=INSERT INTO mobiels (merk, model, totaal, A_kwaliteit, B_kwaliteit, C_kwaliteit, opslag, opmerking) VALUES (?, ?, ?, ?, ?, ?, ?, ?)
INSERT_KABELS=INSERT INTO kabels (model, totaal, lengte, opmerking) VALUES (?, ?, ?, ?)
INSERT_VOEDINGEN=INSERT INTO voedingen (merk, wattage, soort, totaal, nieuw, opmerking) VALUES (?, ?, ?, ?, ?, ?)

DELETE_PRODUCT=DELETE FROM {table} WHERE id=?
